{
  "name": "healthcare-disease-prediction-api",
  "version": "1.0.0",
  "description": "Healthcare Disease Prediction API — Express + MongoDB",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "dev:client": "npm run dev --prefix client",
    "dev:all": "concurrently -n api,web -c blue,magenta \"npm run dev\" \"npm run dev --prefix client\"",
    "build:client": "npm run build --prefix client",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "test:client": "npm run test --prefix client",
    "test:all": "npm run test && npm run test:client"
  },
  "keywords": [
    "healthcare",
    "express",
    "mongodb"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "groq-sdk": "^0.9.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0"
  }
}
